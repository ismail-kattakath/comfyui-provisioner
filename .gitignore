# Local environment + secrets
.env
.env.local
.env.*.local

# Claude Code workspace (personal/local state)
.claude/settings.local.json
.claude/projects/
.claude/worktrees/
.claude/*.lock
.claude/state/

# IDE / dev caches
*.code-workspace
.mypy_cache/
__pycache__/
*.pyc
.DS_Store

# Generated by scripts/refresh-workspace.sh — describes THIS machine's
# working set of comfyui-stack-* siblings, not anything about the tool.
.devcontainer/docker-compose.siblings.yml

# Syncthing instance marker (created by ensure-syncthing.sh; local to each checkout)
.syncthing-instance

# Provisioning runtime artifacts (only created when running on a host)
provision.log
provision_*.log
provision.pid

# Claude Code plugin local config files
*.local.md

# Personal devcontainer stack mounts (private repos, never commit)
.devcontainer/docker-compose.override.yml

# stray runpodctl download artifact (now installed to ~/.local/bin)
runpodctl

# Brainstorming backlog runtime state (structure tracked; live state is per-environment)
.claude/backlog/inbox.jsonl
.claude/backlog/items.json
.claude/backlog/ledger.json
.claude/backlog/.last-dispatch
.claude/backlog/AUTOPILOT
.claude/backlog/PAUSED
