# Export ENV variables to the shell (see .env.example for more details)
[ -f "$PWD/.env" ] && dotenv "$PWD/.env"

# comfy-cli manages the ComfyUI workspace; surface its path for the local
# provisioner and ad-hoc use. `comfy which` prints "Target ComfyUI path: <path>";
# strip the prefix. Respects an explicit COMFYUI_DIR from .env (loaded above),
# and is harmless/empty before `comfy install` has run. Works on any host (Mac
# or devcontainer) that has the comfy CLI installed.
if [ -z "${COMFYUI_DIR:-}" ] && command -v comfy >/dev/null 2>&1; then
  export COMFYUI_DIR="$(comfy which 2>/dev/null | sed -n 's/^Target ComfyUI path: //p' | tail -n1)"
fi
