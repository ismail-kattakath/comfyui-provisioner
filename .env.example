# Civitai API key
CIVITAI_API_KEY=your_civitai_api_key_here

# Hugging Face token
HF_TOKEN=your_hugging_face_token_here

# GitHub Personal Access Token / Output of `gh auth token` command (Make sure to have it granted with necessary permissions for your use cases).
GITHUB_TOKEN=your_github_personal_access_token_or_gh_auth_token_here

# Claude Code OAuth token obrained by `claude setup-token` command
# CLAUDE_CODE_OAUTH_TOKEN=your_claude_code_oauth_token_here

# Vast.ai API key
# VAST_API_KEY=your_vast_ai_api_key_here

# Instance SSH access
# -------------------
# You do NOT need a key path to SSH into instances from the VS Code devcontainer:
# the host SSH agent is forwarded in automatically (SSH_AUTH_SOCK is set). Just load
# your key once ON THE HOST:  ssh-add --apple-use-keychain ~/.ssh/id_ed25519
# Then `ssh` and `vastai ssh-url <id>` work from inside the container, and survive
# container rebuilds. Leave SSH_KEY_FILE unset — skills use plain `ssh` (no -i), so an
# empty/incorrect path would break them. See CLAUDE.md "SSH access from the devcontainer".
#
# SSH_KEY_FILE / SSH_KEY_PUBLIC_FILE are only needed when PROVISIONING new instances
# (vastai attach ssh authorizes the public key). Set them only for that workflow.
# SSH_KEY_FILE=~/.ssh/id_ed25519
# SSH_KEY_PUBLIC_FILE=~/.ssh/id_ed25519.pub

# HUB_PAT_TOKEN=your_docker_hub_pat_token_here
# HUB_USERNAME=your_docker_hub_username_here

# Context7 — optional, free key at context7.com/dashboard for higher rate limits
# CONTEXT7_API_KEY=your_context7_api_key_here

# #Runpod API key
# RUNPOD_API_KEY=your_runpod_api_key_here