{
  "name": "comfyui-provisioner",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers-extra/features/uv:1": {},
    "ghcr.io/esimkowitz/devcontainer-features/direnv:1": {},
    "ghcr.io/devcontainers-extra/features/claude-code:2": {},
    "ghcr.io/devcontainer-community/devcontainer-features/dotenv.org:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspaces,type=bind",
  "workspaceFolder": "/workspaces/comfyui-provisioning",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.config/gh,target=/home/vscode/.config/gh,type=bind"
  ],
  "postCreateCommand": {
    "direnv": "direnv allow .",
    "comfy": "pip install comfy-cli && comfy --install-completion && comfy install --cpu"
  },
  "forwardPorts": [
    8188
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "piiq.code-comfyui",
        "akamud.vscode-theme-onedark",
        "fuadpashayev.bottom-terminal",
        "Anthropic.claude-code",
        "mkhl.direnv"
      ],
      "settings": {
        "workbench.colorTheme": "Atom One Dark",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        }
      }
    }
  }
}