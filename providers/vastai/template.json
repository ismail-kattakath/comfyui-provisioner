{
  "_comment": "VastAI instance template for ComfyUI provisioning. Use with: vastai create instance <offer-id> -f providers/vastai/template.json. Replace STACK_REPO and the env tokens before use.",
  "image": "vastai/comfy:v0.22.0-cuda-12.9-py312",
  "disk": 200,
  "ports": "18188:18188",
  "env": {
    "HF_TOKEN": "REPLACE_ME",
    "CIVITAI_API_KEY": "REPLACE_ME",
    "GH_TOKEN": "REPLACE_ME_if_STACK_REPO_is_private",
    "STACK_REPO": "ismail-kattakath/genai-workflows",
    "STACK_BRANCH": "main"
  },
  "onstart_cmd": "bash <(curl -fsSL https://raw.githubusercontent.com/ismail-kattakath/comfyui-provisioner/main/providers/vastai/onstart.sh)"
}
