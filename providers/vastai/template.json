{
  "_comment": "VastAI instance template for ComfyUI provisioning. The onstart_cmd pulls this repo + your stack repo independently — NO submodule of comfyui-provisioner inside the stack is required.",
  "image": "vastai/comfy:v0.22.0-cuda-12.9-py312",
  "disk": 200,
  "ports": "18188:18188",
  "env": {
    "HF_TOKEN": "REPLACE_ME",
    "CIVITAI_API_KEY": "REPLACE_ME",
    "GH_TOKEN": "REPLACE_ME_if_STACK_REPO_is_private",
    "STACK_REPO": "owner/your-stack-repo",
    "STACK_BRANCH": "main"
  },
  "onstart_cmd": "bash <(curl -fsSL https://raw.githubusercontent.com/ismail-kattakath/comfyui-provisioner/main/providers/vastai/onstart.sh)"
}
